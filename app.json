{
  "expo": {
    "name": "Kash",
    "slug": "kash",
    "description": "Controla tu plata",
    "version": "1.0.0",
    "scheme": "kash",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1F17"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.miguelgallego.finanzas",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usa Face ID para acceder a tus finanzas de forma segura."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1F17"
      },
      "package": "com.miguelgallego.finanzas",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permite usar Face ID para desbloquear la app."
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://miguelgalleg05.github.io/kash/privacy-policy.html"
    },
    "owner": "miguelgallego23"
  }
}
